{
  "name": "vrom.js",
  "version": "3.2.2",
  "description": "Zero-boilerplate RAG for browser AI agents. WASM HNSW vector search + background ONNX embedding + OPFS-cached vROM cartridges.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./embed-worker": {
      "import": {
        "types": "./dist/embed-worker.d.ts",
        "default": "./dist/embed-worker.js"
      },
      "require": {
        "types": "./dist/embed-worker.d.ts",
        "default": "./dist/embed-worker.js"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "wasm-pkg/vrom_js.js",
    "wasm-pkg/vrom_js.d.ts",
    "wasm-pkg/vrom_js_bg.wasm",
    "wasm-pkg/vrom_js_bg.wasm.d.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build:wasm": "wasm-pack build ../src --target bundler --out-dir ../lib/wasm-pkg --release",
    "build:js": "tsdown",
    "build": "npm run build:wasm && npm run build:js",
    "build:check": "tsc --noEmit",
    "lint": "publint",
    "lint:types": "attw --pack . --ignore-rules no-resolution cjs-resolves-to-esm",
    "prepack": "npm run build",
    "clean": "rm -rf dist wasm-pkg"
  },
  "devDependencies": {
    "tsdown": "^0.12.0",
    "typescript": "^5.8.0",
    "publint": "^0.3.0",
    "@arethetypeswrong/cli": "^0.18.0"
  },
  "keywords": [
    "vector-database",
    "hnsw",
    "wasm",
    "webassembly",
    "rag",
    "embeddings",
    "transformers.js",
    "browser",
    "offline",
    "ai-agent",
    "opfs",
    "web-worker"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/philsupertramp/vecdb-wasm"
  },
  "homepage": "https://huggingface.co/spaces/philipp-zettl/vecdb-wasm",
  "sideEffects": false
}
